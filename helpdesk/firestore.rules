rules_version = '2';

// ============================================================
//  Reglas de seguridad a nivel de fila (Row Level Security)
//  HelpDesk ARCE-CEREZO
//  - Nadie accede sin haber iniciado sesión con Firebase Auth.
//  - Cada usuario solo ve y edita SUS propios tickets.
//  - El rol de administrador se lee del documento users/{uid}.
//  - Las contraseñas NO se guardan aquí: las gestiona Firebase Auth.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Funciones auxiliares ----
    function estaAutenticado() {
      return request.auth != null;
    }

    function esAdmin() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function esDueno(recurso) {
      return estaAutenticado() && recurso.data.requesterId == request.auth.uid;
    }

    // ---- Colección de usuarios (perfil y rol, SIN contraseña) ----
    match /users/{uid} {
      // Cada quien lee su propio perfil; el admin lee todos.
      allow read: if request.auth.uid == uid || esAdmin();
      // El usuario solo puede editar su propio perfil y NUNCA su rol.
      allow update: if (request.auth.uid == uid
                        && request.resource.data.role == resource.data.role)
                      || esAdmin();
      // Crear o eliminar usuarios queda reservado al administrador.
      allow create, delete: if esAdmin();
    }

    // ---- Colección de tickets ----
    match /tickets/{ticketId} {
      // Lectura: el dueño del ticket o un administrador.
      allow read: if esDueno(resource) || esAdmin();

      // Creación: cualquier usuario autenticado, pero el ticket debe
      // quedar a su nombre (no puede crear tickets para otros).
      allow create: if estaAutenticado()
                    && request.resource.data.requesterId == request.auth.uid;

      // Actualización y borrado: el dueño o un administrador.
      allow update: if esDueno(resource) || esAdmin();
      allow delete: if esAdmin();
    }

    // ---- Contador atómico de folios ----
    match /meta/{doc} {
      allow read: if estaAutenticado();
      allow write: if estaAutenticado();
    }

    // ---- Todo lo demás queda bloqueado por defecto ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
